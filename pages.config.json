{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "./dist",
  "routes": [
    {
      "path": "/assets/*",
      "target": "./dist"
    },
    {
      "path": "/*",
      "target": "./dist"
    }
  ],
  "edgeFunctions": {
    "routes": [
      {
        "src": "^/api/(.*)$",
        "dest": "/api/[[default]].js"
      }
    ]
  },
  "headers": [
    {
      "source": "/assets/js/*.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/css/*.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/fonts/*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/*.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/assets/*.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/*.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    }
  ],
  "envVariables": {
    "JWT_SECRET": "your-jwt-secret-key-min-32-chars",
    "KV_STORAGE_ID": "your-kv-storage-id",
    "CLOUD_FUNCTION_TOKEN": "your-cloud-function-token"
  },
  "site": {
    "icp": {
      "number": "粤ICP备2026052655号-1",
      "link": "https://beian.miit.gov.cn/"
    },
    "security": {
      "police": {
        "number": "",
        "link": "https://beian.mps.gov.cn/#/"
      }
    }
  }
}
